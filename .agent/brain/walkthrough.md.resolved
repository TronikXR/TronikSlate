def create_project_dir(concept: str, base_dir: str = "") -> str:
    """Create a project folder and return its absolute path.

    Structure:
        <base_dir>/<slug>/
            project.json
            characters/
            images/
            videos/
    """
    if not base_dir:
        base_dir = DEFAULT_PROJECTS_BASE
    slug = slugify_concept(concept)
