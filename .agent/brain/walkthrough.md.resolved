### React Frontend

#### [VideoExport.tsx](file:///F:/pinokio/api/TronikSlate/app/src/components/SmoothBrain/VideoExport.tsx)
```diff:VideoExport.tsx
import { useState, useCallback, useEffect, useRef, useMemo } from 'react';
import { useRenderProgressStore } from '../../stores/renderProgressStore';
import { useUIStore } from '../../stores/uiStore';
import type { SmoothBrainStoryData } from '../../stores/uiStore';
import { useModelStore } from '../../stores/modelStore';
import { AssetPool } from './AssetPool';

/* ─────────────────────────────────────────────────────────── */
/*  Types                                                       */
/* ─────────────────────────────────────────────────────────── */

type VideoStatus = 'pending' | 'rendering' | 'ready' | 'approved' | 'rejected';

interface VideoShot {
    index: number;
    prompt: string;
    status: VideoStatus;
    /** Proxy URL to the storyboard reference image */
    refImagePath: string;
    /** Proxy URL to the generated video */
    videoPath: string | null;
    seed: number;
}

interface Props {
    storyData: SmoothBrainStoryData;
}

/* ─────────────────────────────────────────────────────────── */
/*  Resolution map: vibe × tier → WxH for video generation      */
/* ─────────────────────────────────────────────────────────── */
const VIDEO_RESOLUTION: Record<string, Record<string, string>> = {
    cinematic: { '480p': '832x480', '540p': '960x544', '720p': '1280x720', '1080p': '1920x1080' },
    vertical: { '480p': '480x832', '540p': '544x960', '720p': '720x1280', '1080p': '1080x1920' },
    square: { '480p': '512x512', '540p': '768x768', '720p': '1024x1024', '1080p': '1080x1080' },
};

const GORILLA_GIF = '/gifs/gorillasmoothbrain.gif';

/* ─────────────────────────────────────────────────────────── */
/*  GPU-aware duration limits                                    */
/* ─────────────────────────────────────────────────────────── */

/** Build VRAM→maxDuration lookup for a model family */
function getSmartDuration(vramMB: number, isLtx: boolean) {
    if (isLtx) {
        if (vramMB >= 20480) return { recommended: 20, hardMax: 20 };
        if (vramMB >= 16384) return { recommended: 16, hardMax: 20 };
        if (vramMB >= 12288) return { recommended: 12, hardMax: 20 };
        if (vramMB >= 8192) return { recommended: 8, hardMax: 20 };
        return { recommended: 5, hardMax: 20 };
    }
    // Wan / HunyuanVideo / others
    if (vramMB >= 16384) return { recommended: 10, hardMax: 10 };
    if (vramMB >= 12288) return { recommended: 7, hardMax: 10 };
    if (vramMB >= 8192) return { recommended: 5, hardMax: 10 };
    return { recommended: 5, hardMax: 10 };
}

/* ─────────────────────────────────────────────────────────── */
/*  Component                                                    */
/* ─────────────────────────────────────────────────────────── */
export function VideoExport({ storyData }: Props) {
    const setSmoothBrainPhase = useUIStore((s) => s.setSmoothBrainPhase);

    /* ── Initialise video shots from approved storyboard images ── */
    const [shots, setShots] = useState<VideoShot[]>(() =>
        (storyData.approvedImages || []).map((img, i) => ({
            index: i,
            prompt: storyData.videoPrompts?.[img.index] || img.prompt,
            status: 'pending' as VideoStatus,
            refImagePath: img.imagePath,
            videoPath: null,
            seed: Math.floor(Math.random() * 999999),
        }))
    );

    const [renderJobId, setRenderJobId] = useState<string | null>(null);
    const [renderProgress, setRenderProgress] = useState('');
    const [isRendering, setIsRendering] = useState(false);
    const [autoMode, setAutoMode] = useState(false);
    const [errorMessage, setErrorMessage] = useState<string | null>(null);
    const [fullscreenVideo, setFullscreenVideo] = useState<string | null>(null);
    const [dragOverIndex, setDragOverIndex] = useState<number | null>(null);
    const autoModeRef = useRef(false);
    const eventSourceRef = useRef<EventSource | null>(null);

    /* ── Duration slider state ── */
    const [shotDuration, setShotDuration] = useState(storyData.shotDuration || 5);
    const [advancedMode, setAdvancedMode] = useState(false);
    const [gpuName, setGpuName] = useState('');
    const [gpuVram, setGpuVram] = useState(0);
    const warnAudioRef = useRef<HTMLAudioElement | null>(null);
    const powerAudioRef = useRef<HTMLAudioElement | null>(null);
    const hasPlayedAudioRef = useRef(false);

    const isLtxModel = useMemo(
        () => (storyData.videoModel || '').toLowerCase().startsWith('ltx'),
        [storyData.videoModel]
    );

    const durationLimits = useMemo(
        () => getSmartDuration(gpuVram, isLtxModel),
        [gpuVram, isLtxModel]
    );

    const sliderMax = advancedMode ? durationLimits.hardMax : durationLimits.recommended;

    // GPU detection (same endpoint as ResolutionPicker)
    useEffect(() => {
        fetch('/api/models/gpu')
            .then((r) => r.json())
            .then((data) => {
                setGpuName(data.name || '');
                setGpuVram(data.vramMB || 0);
            })
            .catch(() => { });
    }, []);

    // Clamp duration when switching modes
    useEffect(() => {
        if (shotDuration > sliderMax) setShotDuration(sliderMax);
    }, [sliderMax]);

    // Audio cue on Advanced toggle (plays only once per session)
    const handleAdvancedToggle = useCallback(() => {
        const nextAdvanced = !advancedMode;
        setAdvancedMode(nextAdvanced);
        if (nextAdvanced && !hasPlayedAudioRef.current) {
            hasPlayedAudioRef.current = true;
            // High-tier rig → "DO IT!!", low-tier → "I wouldn't do that!"
            const isHighTier = gpuVram >= 16384;
            const audioEl = isHighTier ? powerAudioRef.current : warnAudioRef.current;
            if (audioEl) {
                audioEl.currentTime = 0;
                audioEl.play().catch(() => { });
            }
        }
    }, [advancedMode, gpuVram]);

    const allApproved = shots.every((s) => s.status === 'approved');
    const pendingCount = shots.filter((s) => s.status === 'pending' || s.status === 'rejected').length;
    const approvedCount = shots.filter((s) => s.status === 'approved').length;

    const getEffectiveDefaults = useModelStore((s) => s.getEffectiveDefaults);

    /* ── SSE cleanup ── */
    useEffect(() => {
        return () => { eventSourceRef.current?.close(); };
    }, []);

    useEffect(() => { autoModeRef.current = autoMode; }, [autoMode]);

    /* ──────────────────────────────── */
    /*  Generate videos for pending shots */
    /* ──────────────────────────────── */
    const handleGenerateVideos = useCallback(async () => {
        const shotsToRender = shots.filter((s) => s.status === 'pending' || s.status === 'rejected');
        if (shotsToRender.length === 0) return;

        console.log('[VideoExport] Starting video generation for', shotsToRender.length, 'shots');
        setErrorMessage(null);

        // Mark rendering
        setShots((prev) =>
            prev.map((s) =>
                s.status === 'pending' || s.status === 'rejected'
                    ? { ...s, status: 'rendering' as VideoStatus }
                    : s
            )
        );
        setIsRendering(true);

        try {
            const videoModelDefaults = getEffectiveDefaults(storyData.videoModel);

            // Calculate video frames from duration
            // LTX 2 requires video_length = 8n+1 (17, 25, 33 ... 241 ...)
            // Other models (Wan, HunyuanVideo) use raw frame count at ~24fps
            const fps = 24;
            const rawFrames = Math.max(1, Math.round(shotDuration * fps));
            const videoLength = isLtxModel
                ? Math.max(17, Math.round((rawFrames - 1) / 8) * 8 + 1)  // snap to nearest 8n+1
                : rawFrames;

            const renderShots = shotsToRender.map((shot) => ({
                prompt: shot.prompt,
                refImagePath: shot.refImagePath || null,
                params: {
                    ...videoModelDefaults,
                    model_type: storyData.videoModel,
                    base_model_type: storyData.videoModel,
                    seed: shot.seed,
                    // VIDEO mode (default)
                    image_mode: 0,
                    video_length: videoLength,
                    resolution: VIDEO_RESOLUTION[storyData.vibe]?.[storyData.videoResolution || storyData.resolution] || '832x480',
                },
            }));

            const res = await fetch('/api/render/start', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    shots: renderShots,
                    defaultParams: videoModelDefaults,
                    projectId: storyData.projectId || 'smoothbrain',
                }),
            });

            const data = await res.json();
            if (!res.ok || !data.ok) {
                const errMsg = data.error || `Server error (${res.status})`;
                console.error('Render start failed:', errMsg);
                setErrorMessage(`❌ ${errMsg}`);
                setShots((prev) =>
                    prev.map((s) =>
                        s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s
                    )
                );
                setIsRendering(false);
                return;
            }

            setRenderJobId(data.jobId);
            useRenderProgressStore.getState().startTracking(data.jobId, shotsToRender.length, 'smoothbrain');

            /* ── SSE listener ── */
            const sse = new EventSource(`/api/render/status/${data.jobId}`);
            eventSourceRef.current = sse;

            sse.onmessage = (event) => {
                try {
                    const msg = JSON.parse(event.data);

                    if (msg.type === 'task_start') {
                        setRenderProgress(`🎬 Generating video ${msg.taskNo}/${shotsToRender.length}...`);
                    }

                    if (msg.type === 'task_done') {
                        const taskIdx = (msg.taskNo || 1) - 1;
                        const actualShot = shotsToRender[taskIdx];
                        if (actualShot) {
                            const proxyUrl = msg.outputPath
                                ? `/api/render/file?path=${encodeURIComponent(msg.outputPath)}`
                                : null;
                            setShots((prev) =>
                                prev.map((s) =>
                                    s.index === actualShot.index
                                        ? {
                                            ...s,
                                            status: autoModeRef.current ? 'approved' as VideoStatus : 'ready' as VideoStatus,
                                            videoPath: proxyUrl,
                                        }
                                        : s
                                )
                            );
                        }
                    }

                    if (msg.type === 'stdout') {
                        setRenderProgress(msg.line || '');
                    }

                    if (msg.type === 'job_end') {
                        sse.close();
                        eventSourceRef.current = null;
                        setIsRendering(false);
                        setRenderProgress('');

                        if (msg.status === 'completed') {
                            setShots((prev) =>
                                prev.map((s) =>
                                    s.status === 'rendering'
                                        ? { ...s, status: autoModeRef.current ? 'approved' as VideoStatus : 'ready' as VideoStatus }
                                        : s
                                )
                            );
                        } else {
                            setShots((prev) =>
                                prev.map((s) =>
                                    s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s
                                )
                            );
                        }
                    }

                    if (msg.type === 'job_error') {
                        sse.close();
                        eventSourceRef.current = null;
                        setIsRendering(false);
                        setRenderProgress('');
                        setShots((prev) =>
                            prev.map((s) =>
                                s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s
                            )
                        );
                    }
                } catch { /* ignore bad JSON */ }
            };

            sse.onerror = () => {
                sse.close();
                eventSourceRef.current = null;
                setIsRendering(false);
            };
        } catch (e) {
            console.error('Render error:', e);
            setIsRendering(false);
            setShots((prev) =>
                prev.map((s) =>
                    s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s
                )
            );
        }
    }, [shots, storyData, getEffectiveDefaults]);

    /* ── Cancel ── */
    const handleCancel = useCallback(async () => {
        if (!renderJobId) return;
        try { await fetch(`/api/render/cancel/${renderJobId}`, { method: 'POST' }); } catch { /* ignore */ }
        eventSourceRef.current?.close();
        eventSourceRef.current = null;
        setIsRendering(false);
        setRenderProgress('');
        setRenderJobId(null);
        setShots((prev) =>
            prev.map((s) => s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s)
        );
    }, [renderJobId]);

    /* ── Approve / Reject ── */
    const handleApprove = useCallback((index: number) => {
        setShots((prev) =>
            prev.map((s) => s.index === index ? { ...s, status: 'approved' as VideoStatus } : s)
        );
    }, []);

    const handleReject = useCallback((index: number) => {
        setShots((prev) =>
            prev.map((s) =>
                s.index === index
                    ? { ...s, status: 'rejected' as VideoStatus, seed: Math.floor(Math.random() * 999999), videoPath: null }
                    : s
            )
        );
    }, []);

    /* ── Grid columns ── */
    const gridCols = shots.length <= 3 ? 'grid-cols-3' : shots.length <= 6 ? 'grid-cols-3' : 'grid-cols-5';

    /* ──────────────────────────────── */
    /*  Render                            */
    /* ──────────────────────────────── */
    return (
        <>
            {/* ── Fullscreen video player overlay ── */}
            {fullscreenVideo && (
                <div
                    className="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-sm"
                    onClick={() => setFullscreenVideo(null)}
                >
                    <button
                        className="absolute top-4 right-4 w-10 h-10 bg-white/10 hover:bg-white/20 rounded-full text-white text-xl flex items-center justify-center transition-colors z-10"
                        onClick={() => setFullscreenVideo(null)}
                    >
                        ✕
                    </button>
                    <video
                        src={fullscreenVideo}
                        className="max-w-[90vw] max-h-[85vh] rounded-xl shadow-2xl"
                        autoPlay
                        controls
                        loop
                        onClick={(e) => e.stopPropagation()}
                    />
                </div>
            )}

            <div className="flex flex-col gap-4 p-4 max-w-4xl mx-auto">
                {/* Header */}
                <div className="flex items-center justify-between">
                    <div className="flex items-center gap-3">
                        <img src="/smoothbrain.jpg" alt="" className="w-10 h-10 rounded" />
                        <div>
                            <h1 className="text-xl font-bold text-white">🏁 Final Round: Video Generation</h1>
                            <p className="text-xs text-gray-500">
                                Turn your storyboard into videos — approve or re-roll
                            </p>
                        </div>
                    </div>
                    <button
                        className="px-3 py-1.5 text-xs bg-surface-300 hover:bg-surface-400 text-gray-300 rounded-md transition-colors"
                        onClick={() => setSmoothBrainPhase('storyboard')}
                    >
                        ← Back to Storyboard
                    </button>
                </div>

                <hr className="border-surface-300" />

                {/* Manual / Automatic toggle */}
                <div className="flex items-center justify-between bg-surface-200/50 px-3 py-2 rounded-lg border border-surface-400">
                    <div>
                        <span className="text-xs text-gray-400">
                            {autoMode ? '🤖 Automatic — videos auto-approve' : '✋ Manual — you approve each video'}
                        </span>
                    </div>
                    <button
                        className="relative w-[120px] h-[28px] rounded-full bg-surface-300 border border-surface-400 flex items-center transition-all cursor-pointer"
                        onClick={() => setAutoMode(!autoMode)}
                        style={{
                            boxShadow: autoMode ? '0 0 12px rgba(34, 197, 94, 0.3)' : 'none',
                            borderColor: autoMode ? 'rgba(34, 197, 94, 0.4)' : undefined,
                        }}
                    >
                        <span className={`absolute left-2 text-[10px] font-medium transition-colors ${!autoMode ? 'text-cyan-300' : 'text-gray-600'}`}>Manual</span>
                        <span className={`absolute right-2 text-[10px] font-medium transition-colors ${autoMode ? 'text-green-300' : 'text-gray-600'}`}>Auto</span>
                        <div
                            className={`absolute top-[2px] w-[54px] h-[22px] rounded-full transition-all duration-200 ${autoMode
                                ? 'left-[63px] bg-green-600'
                                : 'left-[2px] bg-cyan-600'
                                }`}
                        />
                    </button>
                </div>

                {/* ── Duration Slider with Simple/Advanced ── */}
                <div className="bg-surface-200/50 px-4 py-3 rounded-lg border border-surface-400 space-y-3">
                    <div className="flex items-center justify-between">
                        <div className="flex items-center gap-2">
                            <span className="text-xs font-bold text-gray-400 uppercase tracking-wider">⏱️ Shot Duration</span>
                            {gpuName && gpuVram > 0 && (
                                <span className="text-[10px] text-gray-600">
                                    ({gpuName} · {Math.round(gpuVram / 1024)}GB)
                                </span>
                            )}
                        </div>
                        <button
                            className={`px-2.5 py-1 text-[10px] font-bold rounded-full border transition-all ${advancedMode
                                ? 'bg-amber-500/20 border-amber-500/50 text-amber-300 shadow-[0_0_8px_rgba(245,158,11,0.2)]'
                                : 'bg-surface-300 border-surface-400 text-gray-500 hover:text-gray-300'
                                }`}
                            onClick={handleAdvancedToggle}
                        >
                            {advancedMode ? '🔓 Advanced' : '🔒 Simple'}
                        </button>
                    </div>

                    <div className="flex items-center gap-3">
                        <span className="text-xs text-gray-500 w-6 text-right">5s</span>
                        <input
                            type="range"
                            min={5}
                            max={sliderMax}
                            value={shotDuration}
                            onChange={(e) => setShotDuration(Number(e.target.value))}
                            className="flex-1 h-2 rounded-lg appearance-none cursor-pointer accent-purple-500"
                            style={{
                                background: `linear-gradient(to right, #a855f7 ${((shotDuration - 5) / Math.max(1, sliderMax - 5)) * 100}%, #374151 ${((shotDuration - 5) / Math.max(1, sliderMax - 5)) * 100}%)`,
                            }}
                        />
                        <span className="text-xs text-gray-500 w-8">{sliderMax}s</span>
                        <span className="px-2 py-0.5 bg-surface-300 rounded text-xs text-purple-300 tabular-nums whitespace-nowrap">
                            {shotDuration}s per shot
                        </span>
                    </div>

                    {/* Smart hint */}
                    <div className="flex items-center justify-between">
                        <p className="text-[10px] text-gray-600">
                            {!advancedMode ? (
                                <>🧠 Smooth Brain recommends ≤{durationLimits.recommended}s for your rig</>
                            ) : shotDuration > durationLimits.recommended ? (
                                <span className="text-amber-400">⚠️ Above recommended — may be slow or OOM on {gpuName || 'your GPU'}</span>
                            ) : (
                                <>🔓 Full range unlocked — you're still within safe limits</>
                            )}
                        </p>
                        <span className="text-[10px] text-gray-600 tabular-nums">
                            Total: ~{shots.length * shotDuration}s ({shots.length} × {shotDuration}s)
                        </span>
                    </div>
                </div>

                {/* Audio cue elements (play once per session) */}
                <audio ref={warnAudioRef} src="/audio/smoothbrain-warn.wav" preload="auto" />
                <audio ref={powerAudioRef} src="/audio/DO IT DO IT.wav" preload="auto" />

                {/* Model + stats info */}
                <div className="flex items-center gap-4 text-xs text-gray-500">
                    <span>🎥 <strong className="text-white">{storyData.videoModel}</strong></span>
                    <span>{shots.length} shots</span>
                    <span>{shotDuration}s each</span>
                    <span>{storyData.vibe} vibe</span>
                </div>

                {/* Progress bar */}
                <div className="flex items-center gap-3">
                    <div className="flex-1 h-2 bg-surface-300 rounded-full overflow-hidden">
                        <div
                            className="h-full bg-gradient-to-r from-green-500 to-emerald-400 rounded-full transition-all duration-500"
                            style={{ width: `${shots.length > 0 ? (approvedCount / shots.length) * 100 : 0}%` }}
                        />
                    </div>
                    <span className="text-xs text-gray-400 whitespace-nowrap">
                        {approvedCount}/{shots.length} approved
                    </span>
                </div>

                {/* Error banner */}
                {errorMessage && (
                    <div className="flex items-center gap-2 px-3 py-2 bg-red-600/10 border border-red-500/30 rounded-lg">
                        <span className="text-xs text-red-300 flex-1">{errorMessage}</span>
                        <button className="text-xs text-red-400 hover:text-red-200 px-2" onClick={() => setErrorMessage(null)}>✕</button>
                    </div>
                )}

                {/* ── Video grid ── */}
                <div className={`grid ${gridCols} gap-3`}>
                    {shots.map((shot) => (
                        <div
                            key={shot.index}
                            className={`relative flex flex-col rounded-xl overflow-hidden border transition-all ${dragOverIndex === shot.index ? 'border-cyan-400 shadow-lg shadow-cyan-500/20 scale-[1.03]' :
                                shot.status === 'approved' ? 'border-green-500/60 shadow-lg shadow-green-500/10' :
                                    shot.status === 'rejected' ? 'border-red-500/60 shadow-lg shadow-red-500/10' :
                                        shot.status === 'rendering' ? 'border-purple-500/40 shadow-lg shadow-purple-500/10' :
                                            'border-surface-400'
                                }`}
                            onDragOver={(e) => { e.preventDefault(); e.dataTransfer.dropEffect = 'copy'; setDragOverIndex(shot.index); }}
                            onDragLeave={() => setDragOverIndex(null)}
                            onDrop={(e) => {
                                e.preventDefault();
                                setDragOverIndex(null);
                                try {
                                    const json = e.dataTransfer.getData('application/json');
                                    if (json) {
                                        const file = JSON.parse(json);
                                        setShots((prev) => prev.map((s) =>
                                            s.index === shot.index
                                                ? { ...s, videoPath: file.url, status: 'ready' as VideoStatus }
                                                : s
                                        ));
                                        return;
                                    }
                                } catch { /* fallback */ }
                                const url = e.dataTransfer.getData('text/plain');
                                if (url) {
                                    setShots((prev) => prev.map((s) =>
                                        s.index === shot.index
                                            ? { ...s, videoPath: url, status: 'ready' as VideoStatus }
                                            : s
                                    ));
                                }
                            }}
                        >
                            {/* Video / image preview area */}
                            <div className="relative aspect-video bg-surface-200 flex items-center justify-center overflow-hidden">
                                {/* Drop target indicator */}
                                {dragOverIndex === shot.index && (
                                    <div className="absolute inset-0 z-10 flex items-center justify-center bg-cyan-500/20 border-2 border-dashed border-cyan-400 rounded-lg">
                                        <span className="text-cyan-300 font-bold text-sm drop-shadow-lg">⇩ Drop video here</span>
                                    </div>
                                )}
                                {shot.status === 'pending' && (
                                    <div className="flex flex-col items-center gap-1 text-gray-600">
                                        {/* Show storyboard frame as placeholder */}
                                        {shot.refImagePath ? (
                                            <>
                                                <img src={shot.refImagePath} alt="" className="absolute inset-0 w-full h-full object-cover opacity-40" />
                                                <span className="relative text-2xl">🎬</span>
                                                <span className="relative text-[10px]">Ready to render</span>
                                            </>
                                        ) : (
                                            <>
                                                <span className="text-2xl">🎬</span>
                                                <span className="text-[10px]">Waiting...</span>
                                            </>
                                        )}
                                    </div>
                                )}

                                {shot.status === 'rendering' && (
                                    <img src={GORILLA_GIF} alt="Generating..." className="w-full h-full object-cover" />
                                )}

                                {(shot.status === 'ready' || shot.status === 'approved' || shot.status === 'rejected') && shot.videoPath && (
                                    <div className="relative w-full h-full group cursor-pointer" onClick={() => setFullscreenVideo(shot.videoPath)}>
                                        <video
                                            src={shot.videoPath}
                                            className="w-full h-full object-cover"
                                            muted
                                            loop
                                            autoPlay
                                            playsInline
                                        />
                                        {/* Play overlay */}
                                        <div className="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
                                            <div className="w-10 h-10 bg-white/20 group-hover:bg-white/40 rounded-full flex items-center justify-center backdrop-blur-sm transition-all group-hover:scale-110">
                                                <span className="text-white text-lg ml-0.5">▶</span>
                                            </div>
                                        </div>
                                    </div>
                                )}

                                {/* Status badge */}
                                {shot.status === 'approved' && (
                                    <div className="absolute top-1.5 right-1.5 w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-xs shadow-lg">✅</div>
                                )}
                                {shot.status === 'rendering' && (
                                    <div className="absolute top-1.5 right-1.5 px-2 py-0.5 bg-purple-600/80 rounded-full text-[10px] text-white font-medium animate-pulse">Rendering...</div>
                                )}
                                {shot.status === 'rejected' && (
                                    <div className="absolute top-1.5 right-1.5 px-2 py-0.5 bg-red-600/80 rounded-full text-[10px] text-white font-medium">Re-queued</div>
                                )}

                                {/* Shot number */}
                                <div className="absolute top-1.5 left-1.5 w-6 h-6 bg-black/60 rounded-full flex items-center justify-center text-[10px] text-white font-bold">
                                    {shot.index + 1}
                                </div>
                            </div>

                            {/* Prompt */}
                            <div className="px-2 py-1.5 bg-surface-100">
                                <p className="text-[10px] text-gray-400 line-clamp-2 leading-tight" title={shot.prompt}>
                                    {shot.prompt}
                                </p>
                            </div>

                            {/* Approve / Reject buttons — 'ready' status */}
                            {shot.status === 'ready' && (
                                <div className="flex border-t border-surface-400">
                                    <button
                                        className="flex-1 py-1.5 text-sm bg-surface-200 hover:bg-green-600/20 text-green-400 hover:text-green-300 transition-colors border-r border-surface-400"
                                        onClick={() => handleApprove(shot.index)}
                                        title="Approve this video"
                                    >
                                        👍
                                    </button>
                                    <button
                                        className="flex-1 py-1.5 text-sm bg-surface-200 hover:bg-red-600/20 text-red-400 hover:text-red-300 transition-colors"
                                        onClick={() => handleReject(shot.index)}
                                        title="Reject — re-generate with new seed"
                                    >
                                        👎
                                    </button>
                                </div>
                            )}

                            {/* Approved lock */}
                            {shot.status === 'approved' && (
                                <div className="flex border-t border-green-500/30">
                                    <button className="flex-1 py-1.5 text-[10px] bg-green-600/10 text-green-400 font-medium cursor-default" disabled>
                                        ✅ Locked
                                    </button>
                                    <button
                                        className="py-1.5 px-2 text-[10px] bg-surface-200 hover:bg-red-600/10 text-gray-500 hover:text-red-400 transition-colors border-l border-surface-400"
                                        onClick={() => handleReject(shot.index)}
                                        title="Unlock and re-generate"
                                    >
                                        🔓
                                    </button>
                                </div>
                            )}
                        </div>
                    ))}
                </div>

                {/* Render progress */}
                {isRendering && renderProgress && (
                    <div className="flex items-center gap-2 px-3 py-2 bg-purple-600/10 border border-purple-500/30 rounded-lg">
                        <span className="animate-spin text-sm">🎬</span>
                        <span className="text-xs text-purple-300 truncate flex-1">{renderProgress}</span>
                        <button
                            className="text-xs text-red-400 hover:text-red-300 px-2 py-0.5 bg-red-600/20 rounded"
                            onClick={handleCancel}
                        >
                            Cancel
                        </button>
                    </div>
                )}

                {/* Action buttons */}
                <div className="flex gap-3">
                    {!allApproved && (
                        <button
                            className={`flex-1 py-2.5 rounded-xl text-sm font-bold transition-all ${isRendering
                                ? 'bg-surface-400 text-gray-600 cursor-not-allowed'
                                : 'bg-gradient-to-r from-purple-600 to-indigo-500 hover:from-purple-500 hover:to-indigo-400 text-white shadow-lg shadow-purple-600/20 hover:scale-[1.02]'
                                }`}
                            onClick={handleGenerateVideos}
                            disabled={isRendering}
                        >
                            {isRendering
                                ? '🎬 Generating...'
                                : pendingCount === shots.length
                                    ? `🎬 Generate ${shots.length} Videos`
                                    : `🔄 Re-generate ${pendingCount} Rejected Video${pendingCount !== 1 ? 's' : ''}`
                            }
                        </button>
                    )}

                    {allApproved && (
                        <button
                            className="flex-1 py-2.5 rounded-xl text-sm font-bold bg-gradient-to-r from-green-600 to-emerald-500 hover:from-green-500 hover:to-emerald-400 text-white shadow-lg shadow-green-600/30 hover:scale-[1.02] transition-all"
                            onClick={() => {
                                // TODO: final download / export bundle
                                alert('🎉 All videos approved! Export coming soon.');
                            }}
                        >
                            🎉 Export All Videos
                        </button>
                    )}
                </div>

                {/* Asset Pool — shows all previously generated videos for crash recovery */}
                <AssetPool
                    assetType="video"
                    draggable
                    label="🎬 Generated Videos (drag onto a shot or click to preview)"
                    onSelect={(file) => setFullscreenVideo(file.url)}
                />
            </div>
        </>
    );
}
===
import { useState, useCallback, useEffect, useRef, useMemo } from 'react';
import { useRenderProgressStore } from '../../stores/renderProgressStore';
import { useUIStore } from '../../stores/uiStore';
import type { SmoothBrainStoryData } from '../../stores/uiStore';
import { useModelStore } from '../../stores/modelStore';
import { AssetPool } from './AssetPool';

/* ─────────────────────────────────────────────────────────── */
/*  Types                                                       */
/* ─────────────────────────────────────────────────────────── */

type VideoStatus = 'pending' | 'rendering' | 'ready' | 'approved' | 'rejected';

interface VideoShot {
    index: number;
    prompt: string;
    status: VideoStatus;
    /** Proxy URL to the storyboard reference image */
    refImagePath: string;
    /** Proxy URL to the generated video */
    videoPath: string | null;
    seed: number;
}

interface Props {
    storyData: SmoothBrainStoryData;
}

/* ─────────────────────────────────────────────────────────── */
/*  Resolution map: vibe × tier → WxH for video generation      */
/* ─────────────────────────────────────────────────────────── */
const VIDEO_RESOLUTION: Record<string, Record<string, string>> = {
    cinematic: { '480p': '832x480', '540p': '960x544', '720p': '1280x720', '1080p': '1920x1080' },
    vertical: { '480p': '480x832', '540p': '544x960', '720p': '720x1280', '1080p': '1080x1920' },
    square: { '480p': '512x512', '540p': '768x768', '720p': '1024x1024', '1080p': '1080x1080' },
};

const GORILLA_GIF = '/gifs/gorillasmoothbrain.gif';

/* ─────────────────────────────────────────────────────────── */
/*  GPU-aware duration limits                                    */
/* ─────────────────────────────────────────────────────────── */

/** Build VRAM→maxDuration lookup for a model family */
function getSmartDuration(vramMB: number, isLtx: boolean) {
    if (isLtx) {
        if (vramMB >= 20480) return { recommended: 20, hardMax: 20 };
        if (vramMB >= 16384) return { recommended: 16, hardMax: 20 };
        if (vramMB >= 12288) return { recommended: 12, hardMax: 20 };
        if (vramMB >= 8192) return { recommended: 8, hardMax: 20 };
        return { recommended: 5, hardMax: 20 };
    }
    // Wan / HunyuanVideo / others
    if (vramMB >= 16384) return { recommended: 10, hardMax: 10 };
    if (vramMB >= 12288) return { recommended: 7, hardMax: 10 };
    if (vramMB >= 8192) return { recommended: 5, hardMax: 10 };
    return { recommended: 5, hardMax: 10 };
}

/* ─────────────────────────────────────────────────────────── */
/*  Component                                                    */
/* ─────────────────────────────────────────────────────────── */
export function VideoExport({ storyData }: Props) {
    const setSmoothBrainPhase = useUIStore((s) => s.setSmoothBrainPhase);

    /* ── Initialise video shots from approved storyboard images ── */
    const [shots, setShots] = useState<VideoShot[]>(() =>
        (storyData.approvedImages || []).map((img, i) => ({
            index: i,
            prompt: storyData.videoPrompts?.[img.index] || img.prompt,
            status: 'pending' as VideoStatus,
            refImagePath: img.imagePath,
            videoPath: null,
            seed: Math.floor(Math.random() * 999999),
        }))
    );

    const [renderJobId, setRenderJobId] = useState<string | null>(null);
    const [renderProgress, setRenderProgress] = useState('');
    const [isRendering, setIsRendering] = useState(false);
    const [autoMode, setAutoMode] = useState(false);
    const [errorMessage, setErrorMessage] = useState<string | null>(null);
    const [fullscreenVideo, setFullscreenVideo] = useState<string | null>(null);
    const [dragOverIndex, setDragOverIndex] = useState<number | null>(null);
    const [qualityPreset, setQualityPreset] = useState<'fast' | 'balanced' | 'high'>('fast');
    const autoModeRef = useRef(false);
    const eventSourceRef = useRef<EventSource | null>(null);

    /* ── Duration slider state ── */
    const [shotDuration, setShotDuration] = useState(storyData.shotDuration || 5);
    const [advancedMode, setAdvancedMode] = useState(false);
    const [gpuName, setGpuName] = useState('');
    const [gpuVram, setGpuVram] = useState(0);
    const warnAudioRef = useRef<HTMLAudioElement | null>(null);
    const powerAudioRef = useRef<HTMLAudioElement | null>(null);
    const hasPlayedAudioRef = useRef(false);

    const isLtxModel = useMemo(
        () => (storyData.videoModel || '').toLowerCase().startsWith('ltx'),
        [storyData.videoModel]
    );

    const durationLimits = useMemo(
        () => getSmartDuration(gpuVram, isLtxModel),
        [gpuVram, isLtxModel]
    );

    const sliderMax = advancedMode ? durationLimits.hardMax : durationLimits.recommended;

    // GPU detection (same endpoint as ResolutionPicker)
    useEffect(() => {
        fetch('/api/models/gpu')
            .then((r) => r.json())
            .then((data) => {
                setGpuName(data.name || '');
                setGpuVram(data.vramMB || 0);
            })
            .catch(() => { });
    }, []);

    // Clamp duration when switching modes
    useEffect(() => {
        if (shotDuration > sliderMax) setShotDuration(sliderMax);
    }, [sliderMax]);

    // Audio cue on Advanced toggle (plays only once per session)
    const handleAdvancedToggle = useCallback(() => {
        const nextAdvanced = !advancedMode;
        setAdvancedMode(nextAdvanced);
        if (nextAdvanced && !hasPlayedAudioRef.current) {
            hasPlayedAudioRef.current = true;
            // High-tier rig → "DO IT!!", low-tier → "I wouldn't do that!"
            const isHighTier = gpuVram >= 16384;
            const audioEl = isHighTier ? powerAudioRef.current : warnAudioRef.current;
            if (audioEl) {
                audioEl.currentTime = 0;
                audioEl.play().catch(() => { });
            }
        }
    }, [advancedMode, gpuVram]);

    const allApproved = shots.every((s) => s.status === 'approved');
    const pendingCount = shots.filter((s) => s.status === 'pending' || s.status === 'rejected').length;
    const approvedCount = shots.filter((s) => s.status === 'approved').length;

    const getEffectiveDefaults = useModelStore((s) => s.getEffectiveDefaults);

    /* ── SSE cleanup ── */
    useEffect(() => {
        return () => { eventSourceRef.current?.close(); };
    }, []);

    useEffect(() => { autoModeRef.current = autoMode; }, [autoMode]);

    /* ──────────────────────────────── */
    /*  Generate videos for pending shots */
    /* ──────────────────────────────── */
    const handleGenerateVideos = useCallback(async () => {
        const shotsToRender = shots.filter((s) => s.status === 'pending' || s.status === 'rejected');
        if (shotsToRender.length === 0) return;

        console.log('[VideoExport] Starting video generation for', shotsToRender.length, 'shots');
        setErrorMessage(null);

        // Mark rendering
        setShots((prev) =>
            prev.map((s) =>
                s.status === 'pending' || s.status === 'rejected'
                    ? { ...s, status: 'rendering' as VideoStatus }
                    : s
            )
        );
        setIsRendering(true);

        try {
            const videoModelDefaults = getEffectiveDefaults(storyData.videoModel);

            // Calculate video frames from duration
            // LTX 2 requires video_length = 8n+1 (17, 25, 33 ... 241 ...)
            // Other models (Wan, HunyuanVideo) use raw frame count at ~24fps
            const fps = 24;
            const rawFrames = Math.max(1, Math.round(shotDuration * fps));
            const videoLength = isLtxModel
                ? Math.max(17, Math.round((rawFrames - 1) / 8) * 8 + 1)  // snap to nearest 8n+1
                : rawFrames;

            const renderShots = shotsToRender.map((shot) => ({
                prompt: shot.prompt,
                refImagePath: shot.refImagePath || null,
                params: {
                    ...videoModelDefaults,
                    model_type: storyData.videoModel,
                    base_model_type: storyData.videoModel,
                    seed: shot.seed,
                    // VIDEO mode (default)
                    image_mode: 0,
                    video_length: videoLength,
                    resolution: VIDEO_RESOLUTION[storyData.vibe]?.[storyData.videoResolution || storyData.resolution] || '832x480',
                    // Quality preset: override steps for Balanced/High; Fast uses profile defaults
                    ...(qualityPreset !== 'fast' && {
                        num_inference_steps: qualityPreset === 'balanced' ? 25 : 40,
                        // Clear accelerator LoRA settings
                        activated_loras: [],
                        loras_multipliers: '',
                        lset_name: '',
                    }),
                },
            }));

            const res = await fetch('/api/render/start', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    shots: renderShots,
                    defaultParams: videoModelDefaults,
                    projectId: storyData.projectId || 'smoothbrain',
                }),
            });

            const data = await res.json();
            if (!res.ok || !data.ok) {
                const errMsg = data.error || `Server error (${res.status})`;
                console.error('Render start failed:', errMsg);
                setErrorMessage(`❌ ${errMsg}`);
                setShots((prev) =>
                    prev.map((s) =>
                        s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s
                    )
                );
                setIsRendering(false);
                return;
            }

            setRenderJobId(data.jobId);
            useRenderProgressStore.getState().startTracking(data.jobId, shotsToRender.length, 'smoothbrain');

            /* ── SSE listener ── */
            const sse = new EventSource(`/api/render/status/${data.jobId}`);
            eventSourceRef.current = sse;

            sse.onmessage = (event) => {
                try {
                    const msg = JSON.parse(event.data);

                    if (msg.type === 'task_start') {
                        setRenderProgress(`🎬 Generating video ${msg.taskNo}/${shotsToRender.length}...`);
                    }

                    if (msg.type === 'task_done') {
                        const taskIdx = (msg.taskNo || 1) - 1;
                        const actualShot = shotsToRender[taskIdx];
                        if (actualShot) {
                            const proxyUrl = msg.outputPath
                                ? `/api/render/file?path=${encodeURIComponent(msg.outputPath)}`
                                : null;
                            setShots((prev) =>
                                prev.map((s) =>
                                    s.index === actualShot.index
                                        ? {
                                            ...s,
                                            status: autoModeRef.current ? 'approved' as VideoStatus : 'ready' as VideoStatus,
                                            videoPath: proxyUrl,
                                        }
                                        : s
                                )
                            );
                        }
                    }

                    if (msg.type === 'stdout') {
                        setRenderProgress(msg.line || '');
                    }

                    if (msg.type === 'job_end') {
                        sse.close();
                        eventSourceRef.current = null;
                        setIsRendering(false);
                        setRenderProgress('');

                        if (msg.status === 'completed') {
                            setShots((prev) =>
                                prev.map((s) =>
                                    s.status === 'rendering'
                                        ? { ...s, status: autoModeRef.current ? 'approved' as VideoStatus : 'ready' as VideoStatus }
                                        : s
                                )
                            );
                        } else {
                            setShots((prev) =>
                                prev.map((s) =>
                                    s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s
                                )
                            );
                        }
                    }

                    if (msg.type === 'job_error') {
                        sse.close();
                        eventSourceRef.current = null;
                        setIsRendering(false);
                        setRenderProgress('');
                        setShots((prev) =>
                            prev.map((s) =>
                                s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s
                            )
                        );
                    }
                } catch { /* ignore bad JSON */ }
            };

            sse.onerror = () => {
                sse.close();
                eventSourceRef.current = null;
                setIsRendering(false);
            };
        } catch (e) {
            console.error('Render error:', e);
            setIsRendering(false);
            setShots((prev) =>
                prev.map((s) =>
                    s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s
                )
            );
        }
    }, [shots, storyData, getEffectiveDefaults, qualityPreset, shotDuration, isLtxModel]);

    /* ── Cancel ── */
    const handleCancel = useCallback(async () => {
        if (!renderJobId) return;
        try { await fetch(`/api/render/cancel/${renderJobId}`, { method: 'POST' }); } catch { /* ignore */ }
        eventSourceRef.current?.close();
        eventSourceRef.current = null;
        setIsRendering(false);
        setRenderProgress('');
        setRenderJobId(null);
        setShots((prev) =>
            prev.map((s) => s.status === 'rendering' ? { ...s, status: 'pending' as VideoStatus } : s)
        );
    }, [renderJobId]);

    /* ── Approve / Reject ── */
    const handleApprove = useCallback((index: number) => {
        setShots((prev) =>
            prev.map((s) => s.index === index ? { ...s, status: 'approved' as VideoStatus } : s)
        );
    }, []);

    const handleReject = useCallback((index: number) => {
        setShots((prev) =>
            prev.map((s) =>
                s.index === index
                    ? { ...s, status: 'rejected' as VideoStatus, seed: Math.floor(Math.random() * 999999), videoPath: null }
                    : s
            )
        );
    }, []);

    /* ── Grid columns ── */
    const gridCols = shots.length <= 3 ? 'grid-cols-3' : shots.length <= 6 ? 'grid-cols-3' : 'grid-cols-5';

    /* ──────────────────────────────── */
    /*  Render                            */
    /* ──────────────────────────────── */
    return (
        <>
            {/* ── Fullscreen video player overlay ── */}
            {fullscreenVideo && (
                <div
                    className="fixed inset-0 z-50 flex items-center justify-center bg-black/90 backdrop-blur-sm"
                    onClick={() => setFullscreenVideo(null)}
                >
                    <button
                        className="absolute top-4 right-4 w-10 h-10 bg-white/10 hover:bg-white/20 rounded-full text-white text-xl flex items-center justify-center transition-colors z-10"
                        onClick={() => setFullscreenVideo(null)}
                    >
                        ✕
                    </button>
                    <video
                        src={fullscreenVideo}
                        className="max-w-[90vw] max-h-[85vh] rounded-xl shadow-2xl"
                        autoPlay
                        controls
                        loop
                        onClick={(e) => e.stopPropagation()}
                    />
                </div>
            )}

            <div className="flex flex-col gap-4 p-4 max-w-4xl mx-auto">
                {/* Header */}
                <div className="flex items-center justify-between">
                    <div className="flex items-center gap-3">
                        <img src="/smoothbrain.jpg" alt="" className="w-10 h-10 rounded" />
                        <div>
                            <h1 className="text-xl font-bold text-white">🏁 Final Round: Video Generation</h1>
                            <p className="text-xs text-gray-500">
                                Turn your storyboard into videos — approve or re-roll
                            </p>
                        </div>
                    </div>
                    <button
                        className="px-3 py-1.5 text-xs bg-surface-300 hover:bg-surface-400 text-gray-300 rounded-md transition-colors"
                        onClick={() => setSmoothBrainPhase('storyboard')}
                    >
                        ← Back to Storyboard
                    </button>
                </div>

                <hr className="border-surface-300" />

                {/* Manual / Automatic toggle */}
                <div className="flex items-center justify-between bg-surface-200/50 px-3 py-2 rounded-lg border border-surface-400">
                    <div>
                        <span className="text-xs text-gray-400">
                            {autoMode ? '🤖 Automatic — videos auto-approve' : '✋ Manual — you approve each video'}
                        </span>
                    </div>
                    <button
                        className="relative w-[120px] h-[28px] rounded-full bg-surface-300 border border-surface-400 flex items-center transition-all cursor-pointer"
                        onClick={() => setAutoMode(!autoMode)}
                        style={{
                            boxShadow: autoMode ? '0 0 12px rgba(34, 197, 94, 0.3)' : 'none',
                            borderColor: autoMode ? 'rgba(34, 197, 94, 0.4)' : undefined,
                        }}
                    >
                        <span className={`absolute left-2 text-[10px] font-medium transition-colors ${!autoMode ? 'text-cyan-300' : 'text-gray-600'}`}>Manual</span>
                        <span className={`absolute right-2 text-[10px] font-medium transition-colors ${autoMode ? 'text-green-300' : 'text-gray-600'}`}>Auto</span>
                        <div
                            className={`absolute top-[2px] w-[54px] h-[22px] rounded-full transition-all duration-200 ${autoMode
                                ? 'left-[63px] bg-green-600'
                                : 'left-[2px] bg-cyan-600'
                                }`}
                        />
                    </button>
                </div>

                {/* ── Quality Preset ── */}
                <div className="bg-surface-200/50 px-4 py-3 rounded-lg border border-surface-400">
                    <span className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2 block">
                        ⚡ Quality Preset
                    </span>
                    <div className="flex gap-2">
                        {(['fast', 'balanced', 'high'] as const).map((preset) => (
                            <button
                                key={preset}
                                className={`flex-1 py-2 rounded-lg text-xs font-bold transition-all border ${
                                    qualityPreset === preset
                                        ? preset === 'fast'   ? 'bg-cyan-600/20 border-cyan-500/50 text-cyan-300 shadow-[0_0_10px_rgba(6,182,212,0.15)]'
                                        : preset === 'balanced' ? 'bg-purple-600/20 border-purple-500/50 text-purple-300 shadow-[0_0_10px_rgba(168,85,247,0.15)]'
                                        : 'bg-amber-600/20 border-amber-500/50 text-amber-300 shadow-[0_0_10px_rgba(245,158,11,0.15)]'
                                        : 'bg-surface-300 border-surface-400 text-gray-500 hover:text-gray-300'
                                }`}
                                onClick={() => setQualityPreset(preset)}
                                disabled={isRendering}
                            >
                                {preset === 'fast' ? '⚡ Fast' : preset === 'balanced' ? '⚖️ Balanced' : '💎 High'}
                                <span className="block text-[9px] font-normal mt-0.5 opacity-70">
                                    {preset === 'fast' ? 'Lightning LoRA' : preset === 'balanced' ? '25 steps' : '40 steps'}
                                </span>
                            </button>
                        ))}
                    </div>
                </div>

                {/* ── Duration Slider with Simple/Advanced ── */}
                <div className="bg-surface-200/50 px-4 py-3 rounded-lg border border-surface-400 space-y-3">
                    <div className="flex items-center justify-between">
                        <div className="flex items-center gap-2">
                            <span className="text-xs font-bold text-gray-400 uppercase tracking-wider">⏱️ Shot Duration</span>
                            {gpuName && gpuVram > 0 && (
                                <span className="text-[10px] text-gray-600">
                                    ({gpuName} · {Math.round(gpuVram / 1024)}GB)
                                </span>
                            )}
                        </div>
                        <button
                            className={`px-2.5 py-1 text-[10px] font-bold rounded-full border transition-all ${advancedMode
                                ? 'bg-amber-500/20 border-amber-500/50 text-amber-300 shadow-[0_0_8px_rgba(245,158,11,0.2)]'
                                : 'bg-surface-300 border-surface-400 text-gray-500 hover:text-gray-300'
                                }`}
                            onClick={handleAdvancedToggle}
                        >
                            {advancedMode ? '🔓 Advanced' : '🔒 Simple'}
                        </button>
                    </div>

                    <div className="flex items-center gap-3">
                        <span className="text-xs text-gray-500 w-6 text-right">5s</span>
                        <input
                            type="range"
                            min={5}
                            max={sliderMax}
                            value={shotDuration}
                            onChange={(e) => setShotDuration(Number(e.target.value))}
                            className="flex-1 h-2 rounded-lg appearance-none cursor-pointer accent-purple-500"
                            style={{
                                background: `linear-gradient(to right, #a855f7 ${((shotDuration - 5) / Math.max(1, sliderMax - 5)) * 100}%, #374151 ${((shotDuration - 5) / Math.max(1, sliderMax - 5)) * 100}%)`,
                            }}
                        />
                        <span className="text-xs text-gray-500 w-8">{sliderMax}s</span>
                        <span className="px-2 py-0.5 bg-surface-300 rounded text-xs text-purple-300 tabular-nums whitespace-nowrap">
                            {shotDuration}s per shot
                        </span>
                    </div>

                    {/* Smart hint */}
                    <div className="flex items-center justify-between">
                        <p className="text-[10px] text-gray-600">
                            {!advancedMode ? (
                                <>🧠 Smooth Brain recommends ≤{durationLimits.recommended}s for your rig</>
                            ) : shotDuration > durationLimits.recommended ? (
                                <span className="text-amber-400">⚠️ Above recommended — may be slow or OOM on {gpuName || 'your GPU'}</span>
                            ) : (
                                <>🔓 Full range unlocked — you're still within safe limits</>
                            )}
                        </p>
                        <span className="text-[10px] text-gray-600 tabular-nums">
                            Total: ~{shots.length * shotDuration}s ({shots.length} × {shotDuration}s)
                        </span>
                    </div>
                </div>

                {/* Audio cue elements (play once per session) */}
                <audio ref={warnAudioRef} src="/audio/smoothbrain-warn.wav" preload="auto" />
                <audio ref={powerAudioRef} src="/audio/DO IT DO IT.wav" preload="auto" />

                {/* Model + stats info */}
                <div className="flex items-center gap-4 text-xs text-gray-500">
                    <span>🎥 <strong className="text-white">{storyData.videoModel}</strong></span>
                    <span>{shots.length} shots</span>
                    <span>{shotDuration}s each</span>
                    <span>⚡ {qualityPreset}</span>
                    <span>{storyData.vibe} vibe</span>
                </div>

                {/* Progress bar */}
                <div className="flex items-center gap-3">
                    <div className="flex-1 h-2 bg-surface-300 rounded-full overflow-hidden">
                        <div
                            className="h-full bg-gradient-to-r from-green-500 to-emerald-400 rounded-full transition-all duration-500"
                            style={{ width: `${shots.length > 0 ? (approvedCount / shots.length) * 100 : 0}%` }}
                        />
                    </div>
                    <span className="text-xs text-gray-400 whitespace-nowrap">
                        {approvedCount}/{shots.length} approved
                    </span>
                </div>

                {/* Error banner */}
                {errorMessage && (
                    <div className="flex items-center gap-2 px-3 py-2 bg-red-600/10 border border-red-500/30 rounded-lg">
                        <span className="text-xs text-red-300 flex-1">{errorMessage}</span>
                        <button className="text-xs text-red-400 hover:text-red-200 px-2" onClick={() => setErrorMessage(null)}>✕</button>
                    </div>
                )}

                {/* ── Video grid ── */}
                <div className={`grid ${gridCols} gap-3`}>
                    {shots.map((shot) => (
                        <div
                            key={shot.index}
                            className={`relative flex flex-col rounded-xl overflow-hidden border transition-all ${dragOverIndex === shot.index ? 'border-cyan-400 shadow-lg shadow-cyan-500/20 scale-[1.03]' :
                                shot.status === 'approved' ? 'border-green-500/60 shadow-lg shadow-green-500/10' :
                                    shot.status === 'rejected' ? 'border-red-500/60 shadow-lg shadow-red-500/10' :
                                        shot.status === 'rendering' ? 'border-purple-500/40 shadow-lg shadow-purple-500/10' :
                                            'border-surface-400'
                                }`}
                            onDragOver={(e) => { e.preventDefault(); e.dataTransfer.dropEffect = 'copy'; setDragOverIndex(shot.index); }}
                            onDragLeave={() => setDragOverIndex(null)}
                            onDrop={(e) => {
                                e.preventDefault();
                                setDragOverIndex(null);
                                try {
                                    const json = e.dataTransfer.getData('application/json');
                                    if (json) {
                                        const file = JSON.parse(json);
                                        setShots((prev) => prev.map((s) =>
                                            s.index === shot.index
                                                ? { ...s, videoPath: file.url, status: 'ready' as VideoStatus }
                                                : s
                                        ));
                                        return;
                                    }
                                } catch { /* fallback */ }
                                const url = e.dataTransfer.getData('text/plain');
                                if (url) {
                                    setShots((prev) => prev.map((s) =>
                                        s.index === shot.index
                                            ? { ...s, videoPath: url, status: 'ready' as VideoStatus }
                                            : s
                                    ));
                                }
                            }}
                        >
                            {/* Video / image preview area */}
                            <div className="relative aspect-video bg-surface-200 flex items-center justify-center overflow-hidden">
                                {/* Drop target indicator */}
                                {dragOverIndex === shot.index && (
                                    <div className="absolute inset-0 z-10 flex items-center justify-center bg-cyan-500/20 border-2 border-dashed border-cyan-400 rounded-lg">
                                        <span className="text-cyan-300 font-bold text-sm drop-shadow-lg">⇩ Drop video here</span>
                                    </div>
                                )}
                                {shot.status === 'pending' && (
                                    <div className="flex flex-col items-center gap-1 text-gray-600">
                                        {/* Show storyboard frame as placeholder */}
                                        {shot.refImagePath ? (
                                            <>
                                                <img src={shot.refImagePath} alt="" className="absolute inset-0 w-full h-full object-cover opacity-40" />
                                                <span className="relative text-2xl">🎬</span>
                                                <span className="relative text-[10px]">Ready to render</span>
                                            </>
                                        ) : (
                                            <>
                                                <span className="text-2xl">🎬</span>
                                                <span className="text-[10px]">Waiting...</span>
                                            </>
                                        )}
                                    </div>
                                )}

                                {shot.status === 'rendering' && (
                                    <img src={GORILLA_GIF} alt="Generating..." className="w-full h-full object-cover" />
                                )}

                                {(shot.status === 'ready' || shot.status === 'approved' || shot.status === 'rejected') && shot.videoPath && (
                                    <div className="relative w-full h-full group cursor-pointer" onClick={() => setFullscreenVideo(shot.videoPath)}>
                                        <video
                                            src={shot.videoPath}
                                            className="w-full h-full object-cover"
                                            muted
                                            loop
                                            autoPlay
                                            playsInline
                                        />
                                        {/* Play overlay */}
                                        <div className="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
                                            <div className="w-10 h-10 bg-white/20 group-hover:bg-white/40 rounded-full flex items-center justify-center backdrop-blur-sm transition-all group-hover:scale-110">
                                                <span className="text-white text-lg ml-0.5">▶</span>
                                            </div>
                                        </div>
                                    </div>
                                )}

                                {/* Status badge */}
                                {shot.status === 'approved' && (
                                    <div className="absolute top-1.5 right-1.5 w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-xs shadow-lg">✅</div>
                                )}
                                {shot.status === 'rendering' && (
                                    <div className="absolute top-1.5 right-1.5 px-2 py-0.5 bg-purple-600/80 rounded-full text-[10px] text-white font-medium animate-pulse">Rendering...</div>
                                )}
                                {shot.status === 'rejected' && (
                                    <div className="absolute top-1.5 right-1.5 px-2 py-0.5 bg-red-600/80 rounded-full text-[10px] text-white font-medium">Re-queued</div>
                                )}

                                {/* Shot number */}
                                <div className="absolute top-1.5 left-1.5 w-6 h-6 bg-black/60 rounded-full flex items-center justify-center text-[10px] text-white font-bold">
                                    {shot.index + 1}
                                </div>
                            </div>

                            {/* Prompt */}
                            <div className="px-2 py-1.5 bg-surface-100">
                                <p className="text-[10px] text-gray-400 line-clamp-2 leading-tight" title={shot.prompt}>
                                    {shot.prompt}
                                </p>
                            </div>

                            {/* Approve / Reject buttons — 'ready' status */}
                            {shot.status === 'ready' && (
                                <div className="flex border-t border-surface-400">
                                    <button
                                        className="flex-1 py-1.5 text-sm bg-surface-200 hover:bg-green-600/20 text-green-400 hover:text-green-300 transition-colors border-r border-surface-400"
                                        onClick={() => handleApprove(shot.index)}
                                        title="Approve this video"
                                    >
                                        👍
                                    </button>
                                    <button
                                        className="flex-1 py-1.5 text-sm bg-surface-200 hover:bg-red-600/20 text-red-400 hover:text-red-300 transition-colors"
                                        onClick={() => handleReject(shot.index)}
                                        title="Reject — re-generate with new seed"
                                    >
                                        👎
                                    </button>
                                </div>
                            )}

                            {/* Approved lock */}
                            {shot.status === 'approved' && (
                                <div className="flex border-t border-green-500/30">
                                    <button className="flex-1 py-1.5 text-[10px] bg-green-600/10 text-green-400 font-medium cursor-default" disabled>
                                        ✅ Locked
                                    </button>
                                    <button
                                        className="py-1.5 px-2 text-[10px] bg-surface-200 hover:bg-red-600/10 text-gray-500 hover:text-red-400 transition-colors border-l border-surface-400"
                                        onClick={() => handleReject(shot.index)}
                                        title="Unlock and re-generate"
                                    >
                                        🔓
                                    </button>
                                </div>
                            )}
                        </div>
                    ))}
                </div>

                {/* Render progress */}
                {isRendering && renderProgress && (
                    <div className="flex items-center gap-2 px-3 py-2 bg-purple-600/10 border border-purple-500/30 rounded-lg">
                        <span className="animate-spin text-sm">🎬</span>
                        <span className="text-xs text-purple-300 truncate flex-1">{renderProgress}</span>
                        <button
                            className="text-xs text-red-400 hover:text-red-300 px-2 py-0.5 bg-red-600/20 rounded"
                            onClick={handleCancel}
                        >
                            Cancel
                        </button>
                    </div>
                )}

                {/* Action buttons */}
                <div className="flex gap-3">
                    {!allApproved && (
                        <button
                            className={`flex-1 py-2.5 rounded-xl text-sm font-bold transition-all ${isRendering
                                ? 'bg-surface-400 text-gray-600 cursor-not-allowed'
                                : 'bg-gradient-to-r from-purple-600 to-indigo-500 hover:from-purple-500 hover:to-indigo-400 text-white shadow-lg shadow-purple-600/20 hover:scale-[1.02]'
                                }`}
                            onClick={handleGenerateVideos}
                            disabled={isRendering}
                        >
                            {isRendering
                                ? '🎬 Generating...'
                                : pendingCount === shots.length
                                    ? `🎬 Generate ${shots.length} Videos`
                                    : `🔄 Re-generate ${pendingCount} Rejected Video${pendingCount !== 1 ? 's' : ''}`
                            }
                        </button>
                    )}

                    {allApproved && (
                        <button
                            className="flex-1 py-2.5 rounded-xl text-sm font-bold bg-gradient-to-r from-green-600 to-emerald-500 hover:from-green-500 hover:to-emerald-400 text-white shadow-lg shadow-green-600/30 hover:scale-[1.02] transition-all"
                            onClick={() => {
                                // TODO: final download / export bundle
                                alert('🎉 All videos approved! Export coming soon.');
                            }}
                        >
                            🎉 Export All Videos
                        </button>
                    )}
                </div>

                {/* Asset Pool — shows all previously generated videos for crash recovery */}
                <AssetPool
                    assetType="video"
                    draggable
                    label="🎬 Generated Videos (drag onto a shot or click to preview)"
                    onSelect={(file) => setFullscreenVideo(file.url)}
                />
            </div>
        </>
    );
}
```

- New `qualityPreset` state variable
- 3-button toggle UI (cyan/purple/amber color-coded) between Auto/Manual toggle and Duration slider
- When Balanced or High is selected, `num_inference_steps` is overridden (25 or 40) and LoRA settings are cleared in the render params
- Preset name shown in the info bar

## Verification

| Check | Result |
|-------|--------|
| `tsc --noEmit` | ✅ Clean |
| Python `py_compile` (3 files) | ✅ Clean |
| Manual UI test | ⏳ Pending user |
