    slug = re.sub(r"[^a-z0-9\s-]", "", slug)      # strip non-alnum
    slug = re.sub(r"[\s_]+", "-", slug)             # spaces/underscores → hyphens
    slug = re.sub(r"-+", "-", slug).strip("-")      # collapse hyphens
    slug = slug[:max_len].rstrip("-")
