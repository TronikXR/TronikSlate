    "square":    "624x624",
}

def vibe_to_resolution(vibe: str) -> str:
    return VIBE_RESOLUTION.get(vibe, "832x480")


# ── Frame helpers ─────────────────────────────────────────────────────────────

def snap_to_8n1(frames: int) -> int:
    """Snap frame count to nearest 8n+1 (LTX-2 requirement)."""
